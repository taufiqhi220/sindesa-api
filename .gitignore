# Sindesa API - .gitignore

# Upload files (user data, jangan masuk git)
uploads/
*.uploaded

# Debug/Log files
debug.txt
*.log
error_log

# Environment & Config files (private credentials)
.env
.env.local
.env.production
db_config.php

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
*.orig
